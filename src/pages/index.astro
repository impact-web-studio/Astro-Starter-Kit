---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import Services from '../components/home/Services.astro';

import '../styles/css/critical.css';
import '../styles/css/local.css';

const title = 'Pixel Perfect Websites | Code Stitch Web Designs | Denver, CO';
const description = 'Meta description for the page';
const preloadImg = '/assets/images/landing.jpg';
---

<Layout>
	<Hero />
	<Services />

	<script
		slot='head'
		defer
		src='https://identity.netlify.com/v1/netlify-identity-widget.js'
	></script>
	<script slot='head' defer>
		if (window.netlifyIdentity) {
			window.netlifyIdentity.on('init', (user) => {
				if (!user) {
					window.netlifyIdentity.on('login', () => {
						document.location.href = '/admin/';
					});
				}
			});
		}
	</script>
</Layout>
