---
import '../../styles/css/home/hero.css';
---

<section id='hero-2274'>
	<div class='iws-container'>
		<div class='iws-content'>
			<h1 class='iws-title'>We're Building For Better Futures</h1>
			<p class='iws-text'>
				In our relentless pursuit of progress, we are dedicated to constructing
				a future where innovation, sustainability, and inclusivity converge
				seamlessly.
			</p>
			<a
				href=''
				class='iws-button-solid'
			>
				Get Started Today
				<img
					class='iws-button-arrow'
					src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/white-arrow-up.svg'
					decoding='async'
					alt='arrow'
					width='20'
					height='20'
					aria-hidden='true'
				/>
			</a>
		</div>
		<!--To make your own background crops of people use https://www.remove.bg/-->
		<picture class='iws-picture'>
			<source
				media='(max-width: 600px)'
				srcset='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/People/construction-man2.png'
			/>
			<source
				media='(min-width: 601px)'
				srcset='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/People/construction-man2.png'
			/>
			<img
				aria-hidden='true'
				decoding='async'
				src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/People/construction-man2.png'
				alt='construction worker'
				width='581'
				height='662'
			/>
		</picture>
	</div>
	<div class='iws-image-group'>
		<!--Left Image-->
		<picture class='iws-background iws-background1'>
			<source
				media='(max-width: 600px)'
				srcset='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/construction2.jpg'
			/>
			<source
				media='(min-width: 601px)'
				srcset='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/construction2.jpg'
			/>
			<img
				aria-hidden='true'
				decoding='async'
				src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/construction2.jpg'
				alt='construction site'
				width='1290'
				height='684'
			/>
		</picture>
		<!--Right Image-->
		<picture class='iws-background iws-background2'>
			<source
				media='(max-width: 600px)'
				srcset='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/construction1.jpg'
			/>
			<source
				media='(min-width: 601px)'
				srcset='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/construction1.jpg'
			/>
			<img
				aria-hidden='true'
				decoding='async'
				src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/construction1.jpg'
				alt='construction site'
				width='630'
				height='684'
			/>
		</picture>
	</div>
</section>

<!-- ============================================ -->
<!--                  Services                    -->
<!-- ============================================ -->

<section id='Hservices-2274'>
	<div class='iws-container'>
		<ul class='iws-card-group'>
			<li class='iws-item'>
				<a
					href=''
					class='iws-link'
				>
					<img
						class='iws-icon'
						src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/construction1.svg'
						decoding='async'
						alt='icon'
						width='40'
						height='40'
						aria-hidden='true'
					/>
					<h3 class='iws-h3'>Best House Renovation</h3>
					<p class='iws-item-text'>
						Transform your home with trendy flooring and finishes!
					</p>
				</a>
			</li>
			<li class='iws-item'>
				<a
					href=''
					class='iws-link'
				>
					<img
						class='iws-icon'
						src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/construction2.svg'
						decoding='async'
						alt='icon'
						width='40'
						height='40'
						aria-hidden='true'
					/>
					<h3 class='iws-h3'>Quality Always Matters</h3>
					<p class='iws-item-text'>
						Quality renovations provide lasting beauty and functionality.
					</p>
				</a>
			</li>
			<li class='iws-item'>
				<a
					href=''
					class='iws-link'
				>
					<img
						class='iws-icon'
						src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/construction3.svg'
						decoding='async'
						alt='icon'
						width='40'
						height='40'
						aria-hidden='true'
					/>
					<h3 class='iws-h3'>Effective Teamwork</h3>
					<p class='iws-item-text'>
						Collaboration drives success through shared goals and communication.
					</p>
				</a>
			</li>
			<li class='iws-item'>
				<a
					href=''
					class='iws-link'
				>
					<img
						class='iws-icon'
						src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/construction4.svg'
						decoding='async'
						alt='icon'
						width='40'
						height='40'
						aria-hidden='true'
					/>
					<span class='iws-number'>3K+</span>
					<h3 class='iws-h3'>Happy Customers</h3>
					<p class='iws-item-text'>
						With more than 7 years of expertise we served our clients.
					</p>
					<span class='iws-fake-link'>
						Let's Work Together
						<img
							class='iws-arrow'
							src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/orange-arrow-up.svg'
							decoding='async'
							alt='arrow'
							width='20'
							height='20'
							aria-hidden='true'
						/>
					</span>
					<picture class='iws-background'>
						<source
							media='(max-width: 600px)'
							srcset='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/construction3.jpg'
						/>
						<source
							media='(min-width: 601px)'
							srcset='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/construction3.jpg'
						/>
						<img
							aria-hidden='true'
							decoding='async'
							src='https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/construction3.jpg'
							alt='construction site'
							width='630'
							height='684'
						/>
					</picture>
				</a>
			</li>
		</ul>
	</div>
</section>
